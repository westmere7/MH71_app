# =====================================================================
# MH71 environment — copy this file to `.env.local` and fill in values.
# Get the URL + keys from your Supabase project:
#   Project Settings → API
# =====================================================================

# Project URL, e.g. https://abcdxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / publishable key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" / secret key — SERVER ONLY, never exposed to the browser.
# Used only by the /api/meter route handlers.
SUPABASE_SERVICE_ROLE_KEY=

# Password the on-site manager types on the /dien electricity page.
METER_PASSWORD=mh71

# Long random string used to sign the meter-access cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
METER_COOKIE_SECRET=change-me-to-a-long-random-string

# Password to unlock the "Thiết lập giá" (pricing) page. Optional — defaults to
# 77777776 if unset. NEXT_PUBLIC = baked into the build.
NEXT_PUBLIC_PRICING_PASSWORD=77777776
